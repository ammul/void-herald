# Discord
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_CHANNEL_ID=your-channel-id-here

# Path to the claude CLI binary (default: searches PATH)
# CLAUDE_BIN=/home/cedric/.local/bin/claude

# Git repo the bot operates on
REPO_PATH=/absolute/path/to/your/repo

# GitHub webhook (run: openssl rand -hex 32)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ngrok public URL (e.g. https://yourname-abc123.ngrok-free.app)
PUBLIC_URL=https://your-domain.ngrok-free.app

# Optional
PORT=3000
PREFIX=!
# Comma-separated Discord user IDs allowed to use the bot
# Leave blank to deny all users (bot effectively disabled)
ALLOWED_USER_IDS=

# Personality mode — set to NAUGHTY for funny/nasty responses
# MOOD=NAUGHTY

# Usage quota — bot uses QUOTA_SHARE_PCT% of QUOTA_SESSION_USD per session window
# QUOTA_SESSION_USD=10.00  (your full Claude Code budget per session window; 0 = unlimited)
# QUOTA_SHARE_PCT=50       (bot's allowed share of that budget, default 50%)
# QUOTA_WINDOW_HOURS=5     (session window length in hours, default 5h)
# QUOTA_WINDOW_START=21:40 (local HH:MM when your current session started; omit for rolling window)

# GitHub token for fetching failed-step details on pipeline failures (needs read:actions scope)
# GITHUB_TOKEN=github_pat_...
